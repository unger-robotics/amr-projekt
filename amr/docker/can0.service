[Unit]
Description=SocketCAN can0 (MCP2515, 1 Mbit/s)
After=network-pre.target
Wants=network-pre.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c '/sbin/ip link set can0 up type can bitrate 1000000 && /sbin/ip link set can0 txqueuelen 1000'
ExecStop=/sbin/ip link set can0 down

[Install]
WantedBy=multi-user.target
